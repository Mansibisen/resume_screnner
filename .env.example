# ============================================================================
# Resume Screener Configuration (.env)
# ============================================================================
# Copy this file to .env and fill in your values
# Then run: source .env  (or set variables in your terminal)

# ============================================================================
# REQUIRED: OpenAI API Configuration
# ============================================================================
OPENAI_API_KEY=sk-your-api-key-here

# ============================================================================
# LLM Configuration
# ============================================================================
# Model to use: gpt-4, gpt-4-turbo, gpt-4o, gpt-4o-mini, gpt-3.5-turbo
LLM_MODEL=gpt-4o-mini

# Temperature: 0 (deterministic) to 1 (creative)
LLM_TEMPERATURE=0

# ============================================================================
# Resume File Configuration
# ============================================================================
# Path to your resume PDF file (relative to current directory)
RESUME_FILE_PATH=resume.pdf

# ============================================================================
# ChromaDB Configuration
# ============================================================================
# Directory to persist ChromaDB vector store
CHROMA_PERSIST_DIR=./chroma_db

# Collection name for storing resume embeddings
CHROMA_COLLECTION_NAME=my_resume

# ============================================================================
# Text Processing Configuration
# ============================================================================
# Size of text chunks for embedding (larger = more context, fewer embeddings)
CHUNK_SIZE=500

# Overlap between chunks (helps preserve context)
CHUNK_OVERLAP=50

# Number of resume chunks to retrieve for analysis
TOP_K_RESULTS=4

# ============================================================================
# Scoring Thresholds
# ============================================================================
# Minimum score for "Strong Candidate" classification (0-100)
MIN_SCORE_STRONG=75

# Minimum score for "Moderate Candidate" classification (0-100)
MIN_SCORE_MODERATE=60

# Number of improvement suggestions to generate
NUM_SUGGESTIONS=7

# ============================================================================
# Web Scraping Configuration
# ============================================================================
# Timeout for LinkedIn scraping requests (seconds)
SCRAPING_TIMEOUT=10

# User agent string for web requests
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ============================================================================
# Output Configuration
# ============================================================================
# Whether to save results to JSON files
SAVE_RESULTS=false

# Directory to save screening results
RESULTS_OUTPUT_DIR=./screening_results

# Log level: debug, info, warning, error
LOG_LEVEL=info

# ============================================================================
# Advanced Configuration
# ============================================================================
# Enable caching for API calls (reduces cost, may be slightly slower)
ENABLE_CACHING=false

# Maximum retries for failed API calls
MAX_RETRIES=3
